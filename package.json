{
  "name": "gutu-lib-command-palette",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/command-palette build",
    "typecheck": "bun run --cwd framework/libraries/command-palette typecheck",
    "lint": "bun run --cwd framework/libraries/command-palette lint",
    "test": "bun run --cwd framework/libraries/command-palette test",
    "test:unit": "bun run --cwd framework/libraries/command-palette test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
